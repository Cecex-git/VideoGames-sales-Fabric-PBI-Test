{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.6.0/schema.json",
  "name": "sales_trend_titles",
  "position": {
    "x": 24,
    "y": 320,
    "z": 1,
    "height": 360,
    "width": 608,
    "tabOrder": 1
  },
  "visual": {
    "visualType": "lineChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "DimDate"
                    }
                  },
                  "Property": "Year"
                }
              },
              "queryRef": "DimDate.Year",
              "nativeQueryRef": "Year",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "FactGames"
                    }
                  },
                  "Property": "Titles"
                }
              },
              "queryRef": "FactGames.Titles",
              "nativeQueryRef": "Titles"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Column": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "DimDate"
                  }
                },
                "Property": "Year"
              }
            },
            "direction": "Ascending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "drillFilterOtherVisuals": true
  }
}

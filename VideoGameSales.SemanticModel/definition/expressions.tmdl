expression FabricWorkspaceId = "00000000-0000-0000-0000-000000000000" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: 9aa28c2c-c7e6-42ce-a7be-3676d4dd4310


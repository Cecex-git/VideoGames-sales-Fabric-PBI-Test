expression FabricLakehouseId = "11111111-1111-1111-1111-111111111111" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: 12af1f81-2898-4d48-9841-0d3ccb6f223d

/// Source lakehouse table name containing the raw video game sales data.
expression VideoGameSalesLakehouseTable = "VideoGameSalesRaw" meta [IsParameterQuery=true, Type="Text", IsParameterQueryRequired=true]
	lineageTag: 773d4d2a-1e18-4617-b710-e4480fb392e9

/// Normalizes category labels used in dimensions and the fact table.
expression NormalizeCategoryLabel =
		(value as any) as text =>
		    let
		        TextValue = if value = null then "" else Text.Trim(Text.From(value))
		    in
		        if TextValue = "" then "Unknown" else TextValue
	lineageTag: 44cf6155-48bb-49ae-9510-72fb8f6a54bd

/// Normalized category key for case-insensitive relationship joins.
expression NormalizeCategoryKey =
		(value as any) as text =>
		    Text.Upper(NormalizeCategoryLabel(value))
	lineageTag: 335b9177-1d89-4997-8318-5d7d8eb1f9cd

/// Typed base query for the Kaggle video game sales data stored in a Fabric Lakehouse table.
expression VideoGameSalesTypedSource =
		let
		    ParseLakehouseDate = (value as any) as nullable date =>
		        if value = null then
		            null
		        else if Value.Is(value, type date) then
		            Date.From(value)
		        else
		            let
		                TextValue = Text.Trim(Text.From(value)),
		                ParsedValue =
		                    if TextValue = "" then
		                        null
		                    else
		                        let
		                            ParsedDdMmYyyy = try Date.FromText(TextValue, [Format = "dd-MM-yyyy"]),
		                            ParsedIso = if ParsedDdMmYyyy[HasError] then try Date.FromText(TextValue) else ParsedDdMmYyyy
		                        in
		                            if not ParsedDdMmYyyy[HasError] then
		                                ParsedDdMmYyyy[Value]
		                            else if not ParsedIso[HasError] then
		                                ParsedIso[Value]
		                            else
		                                error Error.Record(
		                                    "DataFormat.Error",
		                                    "Unable to parse Lakehouse date value.",
		                                    TextValue
		                                )
		            in
		                ParsedValue,
		    Source = Lakehouse.Contents([CreateNavigationProperties = false, EnableFolding = false]),
		    WorkspaceData = Source{[workspaceId = FabricWorkspaceId]}[Data],
		    LakehouseData = WorkspaceData{[lakehouseId = FabricLakehouseId]}[Data],
		    RequestedTableKey = Text.Upper(Text.Trim(VideoGameSalesLakehouseTable)),
		    CandidateTables = Table.SelectRows(
		        LakehouseData,
		        each Record.FieldOrDefault(_, "ItemKind", null) = "Table"
		    ),
		    MatchingTables = Table.SelectRows(
		        CandidateTables,
		        (row as record) as logical =>
		            List.AnyTrue(
		                List.Transform(
		                    {"Id", "Name", "DisplayName"},
		                    (fieldName as text) as logical =>
		                        let
		                            FieldValue = Record.FieldOrDefault(row, fieldName, null),
		                            NormalizedFieldValue =
		                                if FieldValue = null then
		                                    null
		                                else
		                                    Text.Upper(Text.Trim(Text.From(FieldValue)))
		                        in
		                            NormalizedFieldValue = RequestedTableKey
		                )
		            )
		    ),
		    RawTable =
		        if Table.RowCount(MatchingTables) = 1 then
		            MatchingTables{0}[Data]
		        else if Table.RowCount(MatchingTables) > 1 then
		            error Error.Record(
		                "LakehouseTableAmbiguous",
		                "Multiple Lakehouse tables matched the configured source table name.",
		                [RequestedTable = VideoGameSalesLakehouseTable]
		            )
		        else
		            error Error.Record(
		                "LakehouseTableNotFound",
		                "Unable to find the configured Lakehouse table.",
		                [RequestedTable = VideoGameSalesLakehouseTable]
		            ),
		    TypedColumns = Table.TransformColumnTypes(RawTable, {
		        {"img", type text},
		        {"title", type text},
		        {"console", type text},
		        {"genre", type text},
		        {"publisher", type text},
		        {"developer", type text},
		        {"critic_score", type number},
		        {"total_sales", type number},
		        {"na_sales", type number},
		        {"jp_sales", type number},
		        {"pal_sales", type number},
		        {"other_sales", type number}
		    }),
		    ParsedDates = Table.TransformColumns(
		        TypedColumns,
		        {
		            {"release_date", each ParseLakehouseDate(_), type nullable date},
		            {"last_update", each ParseLakehouseDate(_), type nullable date}
		        }
		    )
		in
		    ParsedDates
	lineageTag: fbd68799-8ec4-45f5-a741-6daec243ee75


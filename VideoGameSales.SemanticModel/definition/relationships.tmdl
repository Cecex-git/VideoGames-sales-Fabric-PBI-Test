relationship FactGames_Console_DimConsole
	fromColumn: FactGames.ConsoleKey
	toColumn: DimConsole.ConsoleKey

relationship FactGames_Genre_DimGenre
	fromColumn: FactGames.GenreKey
	toColumn: DimGenre.GenreKey

relationship FactGames_Publisher_DimPublisher
	fromColumn: FactGames.PublisherKey
	toColumn: DimPublisher.PublisherKey

relationship FactGames_Developer_DimDeveloper
	fromColumn: FactGames.DeveloperKey
	toColumn: DimDeveloper.DeveloperKey

relationship FactGames_ReleaseDate_DimDate
	joinOnDateBehavior: datePartOnly
	fromColumn: FactGames.ReleaseDate
	toColumn: DimDate.Date

